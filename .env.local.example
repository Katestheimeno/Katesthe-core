# Docker Compose environment – copy to .env.local and use with docker compose
#   cp env.docker.example .env.local
# All services read from this file; docker-compose uses env_file only.
#
# Docker network: Postgres service name is `db`. Prefer DB_PRIMARY_HOST=db for Django (direct Postgres).
# Use `pgbouncer` only when pooler auth is aligned (see config/pgbouncer/README.md).
# PGBOUNCER_PORT=6432 is host→container only.

# Django
DJANGO_DEBUG=True
SECRET_KEY=!&c6j^rafut=16n%d^82%p)mke@n#1d^v3@*kxm@w%=si9@*iw
JWT_SECRET_KEY=v604wu=y^uxxyi0!jjembb%v(y#ff$$tq%sejf^ur$$!lh*yy=x9
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database – Django uses DB_PRIMARY_* only (no DATABASE_URL)
#
# Read/write routing (see docs/db-primary-replica.md):
# - WRITES always go to primary. Router defaults ON (DB_ROUTING_ENABLED=true).
# - READS use replicas only when DB_REPLICA_HOSTS lists hosts; if empty, reads stay on primary.
#   Do not point replicas at the same host as primary.
USE_SQLITE=false
DB_PRIMARY_HOST=db
DB_PRIMARY_PORT=5432
DB_PRIMARY_NAME=drf_starter
DB_PRIMARY_USER=postgres
DB_PRIMARY_PASSWORD=postgres
DB_ROUTING_ENABLED=true
# Docker: set to db_replica when using docker-compose streaming replica; leave empty for primary-only
DB_REPLICA_HOSTS=db_replica

# Docker replication user password (primary init + db_replica pg_basebackup); not used by Django directly
REPLICATOR_PASSWORD=replicator_dev
# Optional when using replicas: DB_REPLICA_PORT=5432
# Optional overrides per replica: DB_REPLICA_USER= DB_REPLICA_PASSWORD= DB_REPLICA_NAME=

# Reference: Postgres container + PgBouncer image use the same credentials (see docker-compose.yml)
# Host port for pgbouncer (optional; default 6432)
PGBOUNCER_PORT=6432

# Redis
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/0

# Web
WEB_PORT=8000

# Project
PROJECT_NAME=Katesthe-core
PROJECT_DESCRIPTION=A Django REST Framework starter project with ready-to-use authentication, custom user management, and modular app structure.
PROJECT_VERSION=1.0.0

# Contact
CONTACT_NAME=Katesthe-core Dev Team
CONTACT_EMAIL=support@katesthe-core.com
CONTACT_URL=https://github.com/katesthe-core

# Email (local / MailHog)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FRONTEND_DOMAIN=http://localhost:8000

# Theme
THEME_PRIMARY_COLOR=#6a0dad
THEME_ACCENT_COLOR=#4b0082

# Environment
DJANGO_ENV=local
DJANGO_SETTINGS_MODULE=config.django.local

