## Examples: Complete Flow

### Example 1: Create Endpoint

```python
# 1. Pydantic Request Schema
# schemas/_shop.py
class ShopCreateRequest(BaseModel):
    name: str = Field(..., min_length=1, max_length=100)
    description: Optional[str] = None

# 2. DRF Serializer
# serializers/shop/_create.py
class ShopCreateSerializer(serializers.ModelSerializer):
    class Meta:
        model = Shop
        fields = ['name', 'description']
    
    def create(self, validated_data):
        return Shop.objects.create(**validated_data)

# 3. Controller
# controllers/shop/_create.py
@extend_schema(
    request=ShopCreateRequest,
    responses={201: ShopDetailResponse}
)
def create(self, request):
    # Validate with Pydantic
    request_schema = ShopCreateRequest(**request.data)
    
    # Use DRF for database operations
    serializer = ShopCreateSerializer(data=request_schema.model_dump())
    serializer.is_valid(raise_exception=True)
    shop = serializer.save()
    
    # Return Pydantic response
    return Response(
        ShopDetailResponse.model_validate(shop).model_dump(),
        status=201
    )
```

### Example 2: List Endpoint with Query Params

```python
# 1. Query Params Schema
# schemas/_shop.py
class ShopListQueryParams(BaseModel):
    search: Optional[str] = None
    page: int = Field(1, ge=1)
    page_size: int = Field(20, ge=1, le=100)

# 2. Response Schema
class ShopListResponse(BaseModel):
    id: int
    name: str
    rating: Optional[Decimal] = None

# 3. Controller
@extend_schema(
    parameters=[OpenApiParameter('search', str)],
    responses={200: ShopListResponse}
)
def list(self, request):
    # Validate query params with Pydantic
    query_params = ShopListQueryParams(**request.query_params.dict())
    
    # Use selector for query
    shops = ShopSelector.get_shops(
        search=query_params.search,
        limit=query_params.page_size
    )
    
    # Return Pydantic responses
    return Response([
        ShopListResponse.model_validate(shop).model_dump()
        for shop in shops
    ])
```

