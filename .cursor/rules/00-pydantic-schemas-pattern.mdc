## Integration with DRF Serializers

### Pattern: Pydantic → DRF → Database

```
Request (Pydantic) → Validation → DRF Serializer → Service → Database
                                                              ↓
Response (Pydantic) ← Serialization ← DRF Serializer ← Model Instance
```

### Example: Controller Using Both

```python
# controllers/shop/_create.py
from drf_spectacular.utils import extend_schema
from rest_framework.viewsets import ModelViewSet
from rest_framework.decorators import action
from rest_framework.response import Response
from rest_framework import status

from schemas._shop import ShopCreateRequest, ShopDetailResponse
from serializers.shop._create import ShopCreateSerializer
from services.shop import ShopService

class ShopViewSet(ModelViewSet):
    """Shop management viewset."""
    
    @extend_schema(
        tags=["Shop Management"],
        request=ShopCreateRequest,  # Pydantic schema for request
        responses={201: ShopDetailResponse},  # Pydantic schema for response
    )
    def create(self, request):
        """Create a new shop."""
        # 1. Validate with Pydantic (type checking, basic validation)
        request_schema = ShopCreateRequest(**request.data)
        
        # 2. Use DRF serializer for database operations
        serializer = ShopCreateSerializer(data=request_schema.model_dump())
        serializer.is_valid(raise_exception=True)
        
        # 3. Business logic in service
        shop = ShopService.create_shop(
            user=request.user,
            validated_data=serializer.validated_data
        )
        
        # 4. Return Pydantic response
        response_schema = ShopDetailResponse.model_validate(shop)
        return Response(
            response_schema.model_dump(),
            status=status.HTTP_201_CREATED
        )
```

### Alternative: Direct Pydantic Validation in Serializer

```python
# serializers/shop/_create.py
from rest_framework import serializers
from schemas._shop import ShopCreateRequest
from models import Shop

class ShopCreateSerializer(serializers.ModelSerializer):
    """DRF serializer for shop creation."""
    
    class Meta:
        model = Shop
        fields = ['name', 'description', 'shop_type', 'address', 'latitude', 'longitude']
    
    def validate(self, attrs):
        # Validate with Pydantic first
        try:
            pydantic_data = ShopCreateRequest(**attrs)
            # Pydantic validation passed, now do DRF-specific validation
            return super().validate(attrs)
        except ValidationError as e:
            raise serializers.ValidationError(e.errors())
    
    def create(self, validated_data):
        # Database operation
        return Shop.objects.create(**validated_data)
```

