# API Error Code Enforcement Rule

## ABSOLUTE PROHIBITIONS

NEVER write any of the following in API response code:

### Forbidden: Human-readable strings in responses
```python
# ❌ NEVER
return Response({"error": "User not found"}, status=404)
return Response({"message": "Invalid credentials"}, status=400)
return Response({"detail": "This field is required."}, status=422)
raise ValidationError("Password must be at least 8 characters.")
raise PermissionDenied("You do not have permission to perform this action.")
```

### Forbidden: Unstructured response shapes
```python
# ❌ NEVER
return Response({"status": "error", "msg": "something went wrong"})
return Response({"code": 404, "text": "not found"})
return Response("Unauthorized", status=401)
```

### Forbidden: Non-namespaced codes
```python
# ❌ NEVER
code = "NOT_FOUND"        # missing namespace
code = "error_user"       # wrong case, wrong order
code = "UserNotFound"     # camelCase forbidden
code = "USER_NOT_FOUND_ERROR"  # redundant suffix
```

---

## MANDATORY PATTERNS

### Standard error response (single error)
```python
# ✅ CORRECT
from rest_framework.response import Response
from errors.catalog import USER

def get_user(request, user_id):
    try:
        user = User.objects.get(id=user_id)
    except User.DoesNotExist:
        return Response(
            {
                "success": False,
                "error": {
                    "code": USER["NOT_FOUND"].code,
                },
                "meta": {"request_id": request.id, "version": "v1"},
            },
            status=404,
        )
    return Response({"success": True, "data": UserSerializer(user).data})
```

### Validation errors (multi-error)
```python
# ✅ CORRECT — multiple field errors
from errors.catalog import VALIDATION

errors = [
    {"code": VALIDATION["MISSING_FIELD"].code, "details": {"field": "email", "location": "body"}},
    {"code": VALIDATION["INVALID_FORMAT"].code, "details": {"field": "phone", "location": "body", "expected_format": "E.164"}},
]
return Response(
    {"success": False, "errors": errors, "meta": {"request_id": request.id, "version": "v1"}},
    status=422,
)
```

### DRF custom exception handler
```python
# ✅ CORRECT — global exception handler
from errors.catalog import INTERNAL, VALIDATION, AUTH

def custom_exception_handler(exc, context):
    request = context.get("request")
    request_id = getattr(request, "id", "unknown")
    meta = {"request_id": request_id, "version": "v1"}

    if isinstance(exc, NotAuthenticated):
        return Response(
            {"success": False, "error": {"code": AUTH["UNAUTHENTICATED"].code}, "meta": meta},
            status=401,
        )
    if isinstance(exc, PermissionDenied):
        return Response(
            {"success": False, "error": {"code": "PERMISSION__DENIED"}, "meta": meta},
            status=403,
        )
    if isinstance(exc, ValidationError):
        errors = _normalize_drf_validation_errors(exc.detail)
        return Response(
            {"success": False, "errors": errors, "meta": meta},
            status=422,
        )
    # Fallback — never leak exception messages
    return Response(
        {"success": False, "error": {"code": INTERNAL["ERROR"].code}, "meta": meta},
        status=500,
    )
```

