# 🎛️ Admin Organization Pattern

## Domain-Based Admin Structure

Organize admin functionality by domain/app with separate files for admin configuration, actions, and filters.

## Directory Structure

```bash
admin/
├── __init__.py              # Import and register all admin configs
├── user/
│   ├── __init__.py
│   ├── admin.py             # UserAdmin configuration
│   ├── actions.py           # Custom admin actions for users
│   └── filters.py           # Custom admin filters for users
├── order/
│   ├── __init__.py
│   ├── admin.py             # OrderAdmin configuration
│   ├── actions.py           # Custom admin actions for orders
│   └── filters.py           # Custom admin filters for orders
└── product/
    ├── __init__.py
    ├── admin.py             # ProductAdmin configuration
    ├── actions.py           # Custom admin actions for products
    └── filters.py           # Custom admin filters for products
```

## Admin Configuration (admin.py)

```python
# admin/user/admin.py

from django.contrib import admin
from django.contrib.auth import get_user_model
from .actions import activate_users, deactivate_users, export_users_csv
from .filters import ActiveUserFilter, DateJoinedFilter

User = get_user_model()


@admin.register(User)
class UserAdmin(admin.ModelAdmin):
    """Admin interface for User model."""
    
    list_display = [
        'email',
        'first_name',
        'last_name',
        'is_active',
        'is_staff',
        'date_joined',
    ]
    
    list_filter = [
        ActiveUserFilter,
        DateJoinedFilter,
        'is_staff',
        'is_superuser',
    ]
    
    search_fields = [
        'email',
        'first_name',
        'last_name',
    ]
    
    actions = [
        activate_users,
        deactivate_users,
        export_users_csv,
    ]
    
    readonly_fields = [
        'date_joined',
        'last_login',
    ]
    
    fieldsets = (
        ('Basic Info', {
            'fields': ('email', 'first_name', 'last_name')
        }),
        ('Permissions', {
            'fields': ('is_active', 'is_staff', 'is_superuser', 'groups', 'user_permissions')
        }),
        ('Important dates', {
            'fields': ('last_login', 'date_joined'),
            'classes': ('collapse',)
        }),
    )
    
    # Optimize queries
    def get_queryset(self, request):
        qs = super().get_queryset(request)
        return qs.select_related('profile').prefetch_related('groups')
```

## Admin Actions (actions.py)

```python
# admin/user/actions.py

from django.contrib import admin
from django.http import HttpResponse
from django.utils.html import format_html
import csv


@admin.action(description='Activate selected users')
def activate_users(modeladmin, request, queryset):
    """Bulk activate users."""
    updated = queryset.update(is_active=True)
    modeladmin.message_user(
        request,
        f'{updated} user(s) successfully activated.',
        level='success'
    )


@admin.action(description='Deactivate selected users')
def deactivate_users(modeladmin, request, queryset):
    """Bulk deactivate users."""
    updated = queryset.update(is_active=False)
    modeladmin.message_user(
        request,
        f'{updated} user(s) successfully deactivated.',
        level='success'
    )


@admin.action(description='Export selected users to CSV')
def export_users_csv(modeladmin, request, queryset):
    """Export selected users to CSV file."""
    response = HttpResponse(content_type='text/csv')
    response['Content-Disposition'] = 'attachment; filename="users.csv"'
    
    writer = csv.writer(response)
    writer.writerow(['Email', 'First Name', 'Last Name', 'Is Active', 'Date Joined'])
    
    for user in queryset:
        writer.writerow([
            user.email,
            user.first_name,
            user.last_name,
            user.is_active,
            user.date_joined.strftime('%Y-%m-%d'),
        ])
    
    return response


@admin.action(description='Send welcome email to selected users')
def send_welcome_email(modeladmin, request, queryset):
    """Send welcome email to selected users."""
    from tasks.email import send_welcome_email_task
    
    for user in queryset:
        send_welcome_email_task.delay(user.id)
    
    modeladmin.message_user(
        request,
        f'Welcome email queued for {queryset.count()} user(s).',
        level='success'
    )
```

## Admin Filters (filters.py)

```python
# admin/user/filters.py

from django.contrib import admin
from django.utils import timezone
from datetime import timedelta


class ActiveUserFilter(admin.SimpleListFilter):
    """Filter users by active status with custom options."""
    
    title = 'user status'
    parameter_name = 'status'
    
    def lookups(self, request, model_admin):
        return (
            ('active', 'Active Users'),
            ('inactive', 'Inactive Users'),
            ('staff', 'Staff Users'),
            ('recent', 'Recently Joined'),
        )
    
    def queryset(self, request, queryset):
        if self.value() == 'active':
            return queryset.filter(is_active=True)
        
        if self.value() == 'inactive':
            return queryset.filter(is_active=False)
        
        if self.value() == 'staff':
            return queryset.filter(is_staff=True)
        
        if self.value() == 'recent':
            thirty_days_ago = timezone.now() - timedelta(days=30)
            return queryset.filter(date_joined__gte=thirty_days_ago)


class DateJoinedFilter(admin.SimpleListFilter):
    """Filter users by date joined ranges."""
    
    title = 'date joined'
    parameter_name = 'date_joined'
    
    def lookups(self, request, model_admin):
        return (
            ('today', 'Today'),
            ('week', 'Past Week'),
            ('month', 'Past Month'),
            ('year', 'Past Year'),
        )
    
    def queryset(self, request, queryset):
        now = timezone.now()
        
        if self.value() == 'today':
            return queryset.filter(
                date_joined__date=now.date()
            )
        
        if self.value() == 'week':
            week_ago = now - timedelta(days=7)
            return queryset.filter(date_joined__gte=week_ago)
        
        if self.value() == 'month':
            month_ago = now - timedelta(days=30)
            return queryset.filter(date_joined__gte=month_ago)
        
        if self.value() == 'year':
            year_ago = now - timedelta(days=365)
            return queryset.filter(date_joined__gte=year_ago)


class EmailDomainFilter(admin.SimpleListFilter):
    """Filter users by email domain."""
    
    title = 'email domain'
    parameter_name = 'email_domain'
    
    def lookups(self, request, model_admin):
        # Get unique domains from database
        from django.db.models import CharField
        from django.db.models.functions import Substr, StrIndex
        
        # This is a simplified version - adjust based on your needs
        return (
            ('gmail', 'Gmail'),
            ('yahoo', 'Yahoo'),
            ('hotmail', 'Hotmail'),
            ('company', 'Company Email'),
        )
    
    def queryset(self, request, queryset):
        if self.value():
            return queryset.filter(email__icontains=f'@{self.value()}')
```

